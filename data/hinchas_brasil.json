  "descripcion": "Cantidad base de hinchas por equipo en Brasil, calculada desde prestigio global, capacidad de estadio y liga.",
  "formula": {
    "descripcion": "Se normaliza el prestigio dentro de cada liga y se aplica un porcentaje de ocupación base a la capacidad del estadio.",
    "variables": {
      "prestigio_normalizado": "(prestigio - prestigio_min_liga) / (prestigio_max_liga - prestigio_min_liga)",
      "ocupacion_base": "ocupacion_min_liga + prestigio_normalizado * (ocupacion_max_liga - ocupacion_min_liga)",
      "hinchas_base": "capacidad_estadio * ocupacion_base, redondeado hacia abajo a centenas"
    },
